{
  "manifest_version": 3,
  "name": "WeChat AI-Editor | 公众号 AI 创作助手 (集成豆包)",
  "version": "1.0.0",
  "description": "无需 API Key，直接集成豆包客户端的公众号内容创作助手",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "clipboardRead",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://mp.weixin.qq.com/*",
    "https://www.doubao.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://mp.weixin.qq.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/*", "dist/*"],
      "matches": ["https://mp.weixin.qq.com/*"]
    }
  ]
}
